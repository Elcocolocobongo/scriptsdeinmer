// ==UserScript==
// @name         OTROOO FILL
// @namespace    Violentmonkey Scripts
// @match        https://rumble.com/upload.php*
// @grant        none
// @version      15.1
// @author       Inmer Camacaro
// ==/UserScript==

(function() {
    'use strict';

    let isRedirecting = false;
    let step1Submitted = false;
    let step2Submitted = false;

    const hardClick = (el) => {
        if (!el) return;
        ['mousedown', 'mouseup', 'click'].forEach(type => {
            el.dispatchEvent(new MouseEvent(type, { bubbles: true, cancelable: true, view: window, buttons: 1 }));
        });
    };

    const formatTitle = (name) => {
        return name.replace(/\.[^/.]+$/, "").replace(/_/g, " ").trim();
    };

    const mainLogic = () => {
        if (isRedirecting) return;

        // --- 1. DETECCIÓN DE ELEMENTOS ---
        const fileInput = document.querySelector('input#Filedata');
        const titleInput = document.getElementById('title');
        const hiddenVideoInput = document.querySelector('input[name="video[]"]');

        // LA LLAVE: ¿Rumble ya le asignó un ID al video?
        const isVideoReady = hiddenVideoInput && hiddenVideoInput.value !== "";

        // --- 2. AUTO-LLENADO ---
        if (fileInput && fileInput.files && fileInput.files.length > 0 && titleInput && !titleInput.value) {
            let originalName = fileInput.files[0].name;
            titleInput.value = formatTitle(originalName);
            titleInput.dispatchEvent(new Event('input', { bubbles: true }));
        }

        const catInput = document.querySelector('input[name="primary-category"]');
        if (catInput && !catInput.value) {
            catInput.click();
            setTimeout(() => {
                const entOption = document.querySelector('div.select-option[data-value="15"]');
                if (entOption) {
                    hardClick(entOption);
                    catInput.dispatchEvent(new Event('change', { bubbles: true }));
                    catInput.blur();
                }
            }, 150);
        }

        const privInput = document.getElementById('visibility_private');
        if (privInput && !privInput.checked) {
            document.querySelector('label[for="visibility_private"]')?.click();
        }

        // --- 3. DISPARO DEL PRIMER UPLOAD ---
        const uploadBtn = document.getElementById('submitForm');

        if (!step1Submitted && isVideoReady && titleInput?.value && catInput?.value && privInput?.checked && uploadBtn && uploadBtn.offsetParent !== null) {
            console.log("🎯 Video detectado en el sistema. Pulsando Upload...");
            step1Submitted = true;
            hardClick(uploadBtn);
        }

        // --- 4. LICENCIAS Y ENVÍO FINAL ---
        const personalBtn = document.querySelector('a.greenLink[crcval="0"]');
        if (personalBtn) {
            const container = personalBtn.closest('.wight-box');
            if (container && !container.classList.contains('active-wight-box')) {
                hardClick(personalBtn);
                hardClick(container);
            }
        }

        const c1 = document.getElementById('crights');
        const c2 = document.getElementById('cterms');
        if (c1 && !c1.checked) document.querySelector('label[for="crights"]')?.click();
        if (c2 && !c2.checked) document.querySelector('label[for="cterms"]')?.click();

        const submitBtn2 = document.getElementById('submitForm2');
        if (!step2Submitted && c1?.checked && c2?.checked && submitBtn2 && submitBtn2.offsetParent !== null) {
            console.log("🚀 Enviando paso final...");
            step2Submitted = true;
            hardClick(submitBtn2);
        }

        // --- 5. RETORNO TURBO ---
        const successMessage = Array.from(document.getElementsByTagName('h3'))
                                    .find(h => h.textContent.trim() === "Video Upload Complete!" && h.offsetParent !== null);

        if (successMessage) {
            isRedirecting = true;
            console.log("✅ ¡Listo! Volviendo a la carga...");
            window.location.href = "https://rumble.com/upload.php";
        }
    };

    setInterval(mainLogic, 400);
})();
